# PostgreSQL
POSTGRES_USER=arma
POSTGRES_PASSWORD=armapassword
POSTGRES_DB=arma

# ARMA Settings (all prefixed ARMA_)
ARMA_DATABASE_URL=postgresql+asyncpg://arma:armapassword@postgres:5432/arma
ARMA_NEO4J_URI=bolt://neo4j:7687
ARMA_NEO4J_USER=neo4j
ARMA_NEO4J_PASSWORD=armapassword
ARMA_REDIS_URL=redis://redis:6379/0
ARMA_ENCRYPTION_KEY=<generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
ARMA_EMBEDDING_PROVIDER=local
ARMA_EMBEDDING_BASE_URL=http://host.docker.internal:1234/v1
ARMA_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
ARMA_OPENAI_API_KEY=
ARMA_API_KEY=<your-api-key>
ARMA_WEBHOOK_BASE_URL=https://your-domain.com
ARMA_REPOS_DIR=/app/repos
ARMA_MAX_DISK_GB=50
ARMA_ENV=development
ARMA_CORS_ORIGINS=*
